---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books', (e) => e.id.startsWith('en/'));
  return books.map(entry => ({
    params: { book: entry.data.id },
    props: { book: entry.data },
  }));
}

const { book } = Astro.props;

const siteBase = 'https://estudobiblico.pages.dev';
const canonicalUrl = `${siteBase}/en/${book.id}`;
const altLangUrl   = `${siteBase}/pt/${book.id}`;
---

<BaseLayout
  title={`${book.title} — Bible Study`}
  description={`${book.abbr} · ${book.tags.join(', ')}`}
  lang="en"
  canonicalUrl={canonicalUrl}
  altLang={{ lang: 'pt', url: altLangUrl }}
>

<style>
  .book-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 60px 16px 80px;
  }
  .back-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
  }
  .back-link {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sand-dim);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color .2s;
  }
  .back-link:hover { color: var(--gold); }
  .lang-link {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    padding: 6px 14px;
    border-radius: 50px;
    border: 1px solid rgba(255,164,0,.3);
    background: var(--navy-mid);
    color: var(--gold);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    transition: background .2s, color .2s;
  }
  .lang-link:hover { background: var(--gold); color: var(--navy); }

  .mhead { margin-bottom: 20px; padding-bottom: 18px; border-bottom: 1px solid rgba(255,164,0,.12); }
  .mnum { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 3.5px; color: var(--gold); opacity: .65; margin-bottom: 8px; text-transform: uppercase; }
  .mtitle { font-family: 'Cinzel Decorative', serif; font-size: 36px; font-weight: 700; color: var(--sand); line-height: 1.1; margin-bottom: 8px; }
  .mabbr { font-family: 'Cinzel', serif; font-size: 11px; color: var(--sand-dim); letter-spacing: 1.5px; opacity: .8; }
  .mauthor { display: inline-flex; align-items: center; gap: 6px; margin-top: 10px; font-family: 'Cinzel', serif; font-size: 11px; color: var(--gold); letter-spacing: .5px; }
  .mauthor svg { flex-shrink: 0; opacity: .7; }
  .mchars { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .mchar-label { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold); opacity: .55; margin-top: 10px; display: block; }
  .mchar-tag { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: .8px; padding: 3px 11px; border-radius: 20px; background: rgba(255,164,0,.08); border: 1px solid rgba(255,164,0,.22); color: var(--sand-dim); }
  .mtags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; }
  .mtag { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; background: rgba(255,164,0,.10); color: var(--gold); padding: 4px 12px; border-radius: 20px; border: 1px solid rgba(255,164,0,.18); }
  .msecttitle { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 4px; text-transform: uppercase; color: var(--gold); opacity: .6; margin: 0 0 14px; }
  .mbody { font-family: 'EB Garamond', serif; font-size: 17px; line-height: 1.82; color: var(--sand); opacity: .92; text-align: justify; hyphens: auto; }
  .mbody :global(p) { margin-bottom: 14px; }
  .mbody :global(p:last-child) { margin-bottom: 0; }
  .mbody :global(strong) { color: var(--gold); font-weight: 600; }
  .mverse { font-family: 'EB Garamond', serif; font-style: italic; font-size: 17px; color: var(--sand-dim); opacity: .9; border-left: 3px solid var(--gold); padding: 12px 0 12px 20px; margin-top: 24px; line-height: 1.7; background: rgba(255,164,0,.04); border-radius: 0 8px 8px 0; }
  .mverse :global(cite) { display: block; font-style: normal; font-size: 11px; font-family: 'Cinzel', serif; letter-spacing: 1.5px; opacity: .6; margin-top: 8px; color: var(--gold); }
  .translation-badge { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--sand-dim); opacity: .55; margin-bottom: 18px; display: block; }
</style>

<div class="book-page">
  <div class="back-row">
    <a href="/en" class="back-link">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      Canon
    </a>
    <a href={altLangUrl} class="lang-link">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      PT
    </a>
  </div>

  <div class="mhead">
    <div class="mnum">{book.num}</div>
    <div class="mtitle">{book.title}</div>
    <div class="mabbr">{book.abbr}</div>
    {book.author && (
      <div class="mauthor">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {book.author}
      </div>
    )}
    {book.chars && book.chars.length > 0 && (
      <>
        <span class="mchar-label">Main characters</span>
        <div class="mchars">
          {book.chars.map(c => <span class="mchar-tag">{c}</span>)}
        </div>
      </>
    )}
  </div>

  <div class="mtags">
    {book.tags.map(t => <span class="mtag">{t}</span>)}
  </div>

  <span class="translation-badge">Translation: {book.translation}</span>

  <div class="msecttitle">Context &amp; Summary</div>
  <div class="mbody" set:html={book.body} />

  {book.verse && (
    <div class="mverse" set:html={book.verse} />
  )}
</div>

</BaseLayout>
