---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books', (entry) => entry.id.startsWith('en/'));
const db = Object.fromEntries(books.map(b => [b.data.id, b.data]));

const byOrder = (ids: string[]) => ids.map(id => db[id]).filter(Boolean);

const groups = [
  { ids: ['gn','ex','lv','nm','dt'],                          cat: 'pen', cols: 'r5',  label: 'Pentateuch · Law · 5 books',           href: '/en/at-pentateuco' },
  { ids: ['js','jz','rt','sm1','sm2','rs1','rs2','cr1','cr2','ed','ne','et'], cat: 'his', cols: 'r12', label: 'Historical · 12 books', href: '/en/at-historicos' },
  { ids: ['jo','sl','pv','ec','ct'],                          cat: 'poe', cols: 'r5',  label: 'Poetic · Wisdom · 5 books',            href: '/en/at-poeticos' },
  { ids: ['is','jr','lm','ez','dn'],                          cat: 'mai', cols: 'r5',  label: 'Major Prophets · 5 books',             href: '/en/at-profetas-maiores' },
  { ids: ['os','jl','am','ob','jn','mq','na','hc','sf','ag','zc','ml'], cat: 'men', cols: 'r12', label: 'Minor Prophets · 12 books', href: '/en/at-profetas-menores' },
];

const ntGroups = [
  { ids: ['mt','mc','lc','joe'],                              cat: 'eva', cols: 'r4',  label: 'Gospels · 4 books',                    href: '/en/nt-evangelhos' },
  { ids: ['at'],                                              cat: 'ato', cols: 'r1',  label: 'Historical · NT · 1 book',             href: null },
  { ids: ['rm','co1','co2','gl','ef','fp','cl','ts1','ts2','tm1','tm2','tt','fm'], cat: 'pau', cols: 'r13', label: 'Pauline Epistles · 13 books', href: null },
  { ids: ['hb','tg','pe1','pe2','jo1','jo2','jo3','jd'],     cat: 'ger', cols: 'r8',  label: 'General Epistles · 8 books',           href: null },
  { ids: ['ap'],                                             cat: 'apo', cols: 'r1',  label: 'Prophetic · NT · 1 book',              href: null },
];

// Serialize DB for client-side modal
const dbJson = JSON.stringify(Object.fromEntries(
  books.map(b => [b.data.id, {
    num: b.data.num,
    title: b.data.title,
    abbr: b.data.abbr,
    author: b.data.author ?? '',
    chars: b.data.chars ?? [],
    tags: b.data.tags ?? [],
    body: b.data.body ?? '',
    verse: b.data.verse ?? '',
  }])
));
---

<BaseLayout
  title="Bible Study — Protestant Canon · 66 Books"
  description="Complete study of all 66 Bible books with historical context, theology, and key verses. ESV translation."
  lang="en"
  canonicalUrl="https://estudobiblico.pages.dev/en"
  altLang={{ lang: 'pt', url: 'https://estudobiblico.pages.dev/pt' }}
>

<!-- TOOLBAR -->
<div class="toolbar">
  <a href="/pt" class="tbtn" aria-label="Mudar para Português">
    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    PT
  </a>
</div>

<div class="header">
  <div class="eyebrow">Protestant Canon · 66 Books</div>
  <h1>Biblical <em>Study</em></h1>
  <p class="subline"><strong>Click any book to see its context and full summary</strong></p>
  <div class="rule"></div>
</div>

<div class="stats">
  <div class="stat"><span class="stat-n">66</span><span class="stat-l">Total</span></div>
  <div class="stat"><span class="stat-n">39</span><span class="stat-l">Old Testament</span></div>
  <div class="stat"><span class="stat-n">27</span><span class="stat-l">New Testament</span></div>
</div>

<div class="ptable">

  <div class="tdiv"><div class="tline r"></div><div class="tlabel">✦ OLD TESTAMENT ✦</div><div class="tline"></div></div>

  {groups.map(group => (
    <>
      {group.href
        ? <a href={group.href} class="slabel slabel-link">{group.label}</a>
        : <div class="slabel">{group.label}</div>
      }
      <div class={`g ${group.cols}`}>
        {byOrder(group.ids).map(book => (
          book.id === 'at'
            ? <button onclick={`show('${book.id}')`} class={`cell ${book.category}`} style="aspect-ratio:4/1.18;flex-direction:row;justify-content:flex-start;gap:12px;padding:10px 16px;">
                <span class="cn" style="font-size:13px;">{book.order}</span>
                <span class="ca" style="font-size:22px;">{book.cellAbbr}</span>
                <span class="cname" style="font-size:13px;text-align:left;">{book.title}</span>
              </button>
            : <button onclick={`show('${book.id}')`} class={`cell ${book.category}`}>
                <span class="cn">{book.order}</span>
                <span class="ca">{book.cellAbbr}</span>
                <span class="cname">{book.title}</span>
              </button>
        ))}
      </div>
    </>
  ))}

  <div class="tdiv"><div class="tline r"></div><div class="tlabel">✦ NEW TESTAMENT ✦</div><div class="tline"></div></div>

  {ntGroups.map(group => (
    <>
      <div class="slabel">{group.label}</div>
      <div class={`g ${group.cols}`}>
        {byOrder(group.ids).map(book => (
          (group.ids.length === 1 && group.cat !== 'eva')
            ? <button onclick={`show('${book.id}')`} class={`cell ${book.category}`} style="aspect-ratio:4/1.18;flex-direction:row;justify-content:flex-start;gap:12px;padding:10px 16px;">
                <span class="cn" style="font-size:13px;">{book.order}</span>
                <span class="ca" style="font-size:22px;">{book.cellAbbr}</span>
                <span class="cname" style="font-size:13px;text-align:left;">{book.title}</span>
              </button>
            : <button onclick={`show('${book.id}')`} class={`cell ${book.category}`}>
                <span class="cn">{book.order}</span>
                <span class="ca">{book.cellAbbr}</span>
                <span class="cname">{book.title}</span>
              </button>
        ))}
      </div>
    </>
  ))}

</div>

<!-- LEGEND -->
<div class="tdiv" style="max-width:1100px;margin:28px auto 0;"><div class="tline r"></div><div class="tlabel">✦ LEGEND ✦</div><div class="tline"></div></div>
<div class="legend">
  <div class="li"><div class="lsw" style="background:rgba(255,164,0,.14);border:1px solid rgba(255,164,0,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--pen)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg></div><div><span class="lcat" style="color:var(--pen)">OT · Law</span><span class="lname" style="color:var(--pen)">Pentateuch</span></div><span class="lcount">5</span></div>
  <div class="li"><div class="lsw" style="background:rgba(232,130,10,.14);border:1px solid rgba(232,130,10,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--his)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div><div><span class="lcat" style="color:var(--his)">OT · Narrative</span><span class="lname" style="color:var(--his)">Historical</span></div><span class="lcount">12</span></div>
  <div class="li"><div class="lsw" style="background:rgba(240,192,64,.14);border:1px solid rgba(240,192,64,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--poe)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div><div><span class="lcat" style="color:var(--poe)">OT · Wisdom</span><span class="lname" style="color:var(--poe)">Poetic</span></div><span class="lcount">5</span></div>
  <div class="li"><div class="lsw" style="background:rgba(224,106,16,.14);border:1px solid rgba(224,106,16,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--mai)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="M13 13l6 6"/></svg></div><div><span class="lcat" style="color:var(--mai)">OT · Prophecy</span><span class="lname" style="color:var(--mai)">Maj. Prophets</span></div><span class="lcount">5</span></div>
  <div class="li"><div class="lsw" style="background:rgba(212,160,32,.14);border:1px solid rgba(212,160,32,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--men)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div><div><span class="lcat" style="color:var(--men)">OT · Prophecy</span><span class="lname" style="color:var(--men)">Min. Prophets</span></div><span class="lcount">12</span></div>
  <div class="li"><div class="lsw" style="background:rgba(255,184,48,.14);border:1px solid rgba(255,184,48,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--eva)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></div><div><span class="lcat" style="color:var(--eva)">NT · Biography</span><span class="lname" style="color:var(--eva)">Gospels</span></div><span class="lcount">4</span></div>
  <div class="li"><div class="lsw" style="background:rgba(200,120,32,.14);border:1px solid rgba(200,120,32,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--ato)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div><div><span class="lcat" style="color:var(--ato)">NT · Narrative</span><span class="lname" style="color:var(--ato)">Acts</span></div><span class="lcount">1</span></div>
  <div class="li"><div class="lsw" style="background:rgba(240,144,10,.14);border:1px solid rgba(240,144,10,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--pau)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div><div><span class="lcat" style="color:var(--pau)">NT · Epistle</span><span class="lname" style="color:var(--pau)">Pauline</span></div><span class="lcount">13</span></div>
  <div class="li"><div class="lsw" style="background:rgba(232,184,64,.14);border:1px solid rgba(232,184,64,.35)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--ger)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div><div><span class="lcat" style="color:var(--ger)">NT · Epistle</span><span class="lname" style="color:var(--ger)">General</span></div><span class="lcount">8</span></div>
  <div class="li"><div class="lsw" style="background:rgba(204,96,16,.14);border:1px solid rgba(204,96,16,.4)"><svg viewBox="0 0 24 24" fill="none" stroke="var(--apo)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 6v16l7-4 8 4 7-4V2l-7 4-8-4-7 4z"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg></div><div><span class="lcat" style="color:var(--apo)">NT · Prophecy</span><span class="lname" style="color:var(--apo)">Revelation</span></div><span class="lcount">1</span></div>
</div>

<!-- MODAL OVERLAY -->
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal" id="modal" role="dialog" aria-modal="true" aria-labelledby="m-title">
    <button class="mclose" onclick="close_()" aria-label="Close">
      <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="modal-inner">
      <div class="mhead">
        <div class="mnum" id="m-num"></div>
        <div class="mtitle" id="m-title"></div>
        <div class="mabbr" id="m-abbr"></div>
        <div class="mauthor" id="m-author" style="display:none">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span id="m-author-text"></span>
        </div>
        <div id="m-chars-wrap" style="display:none">
          <span class="mchar-label">Key figures</span>
          <div class="mchars" id="m-chars"></div>
        </div>
      </div>
      <div class="mtags" id="m-tags"></div>
      <div class="msecttitle">Context &amp; Summary</div>
      <div class="mbody" id="m-body"></div>
      <div class="mverse" id="m-verse" style="display:none"></div>
    </div>
  </div>
</div>

<style>
  .cell { background: none; text-align: inherit; font: inherit; color: inherit; cursor: pointer; }
</style>

<script define:vars={{ dbJson }}>
const DB = JSON.parse(dbJson);

window.show = function(id) {
  const b = DB[id]; if (!b) return;
  document.getElementById('m-num').textContent   = b.num;
  document.getElementById('m-title').textContent = b.title;
  document.getElementById('m-abbr').textContent  = b.abbr;
  const au = document.getElementById('m-author');
  document.getElementById('m-author-text').textContent = b.author || '';
  au.style.display = b.author ? 'inline-flex' : 'none';
  const cw = document.getElementById('m-chars-wrap');
  const cc = document.getElementById('m-chars');
  if (b.chars && b.chars.length) {
    cc.innerHTML = b.chars.map(c => `<span class="mchar-tag">${c}</span>`).join('');
    cw.style.display = 'block';
  } else { cw.style.display = 'none'; }
  document.getElementById('m-tags').innerHTML = (b.tags || []).map(t => `<span class="mtag">${t}</span>`).join('');
  document.getElementById('m-body').innerHTML  = b.body;
  const ve = document.getElementById('m-verse');
  ve.innerHTML = b.verse || '';
  ve.style.display = b.verse ? 'block' : 'none';
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
  document.getElementById('modal').scrollTop = 0;
};

window.close_ = function() {
  document.getElementById('overlay').classList.remove('open');
  document.body.style.overflow = '';
};

window.closeModal = function(e) {
  if (e.target === document.getElementById('overlay')) window.close_();
};

document.addEventListener('keydown', e => { if (e.key === 'Escape') window.close_(); });

try { localStorage.setItem('lang', 'en'); } catch(e) {}
</script>

</BaseLayout>
