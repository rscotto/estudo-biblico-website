---
export interface Props {
  title: string;
  description?: string;
  lang: 'pt' | 'en';
  canonicalUrl?: string;
  altLang?: { lang: string; url: string };
  accentColor: string;
  navW?: string;
}

const {
  title,
  description,
  lang,
  canonicalUrl,
  altLang,
  accentColor,
  navW = '272px',
} = Astro.props;

const htmlLang = lang === 'en' ? 'en' : 'pt-BR';
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
{description && <meta name="description" content={description} />}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
{altLang && <link rel="alternate" hreflang={altLang.lang} href={altLang.url} />}
<link rel="alternate" hreflang={lang} href={canonicalUrl} />
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/shared.css">
<style is:inline set:html={`
  :root {
    --navy: #2c2416;
    --navy-mid: #3a3020;
    --navy-light: #4a3e28;
    --gold: #FFA400;
    --gold-dim: #cc8500;
    --sand: #f0e6d0;
    --sand-dim: #c8b898;
    --accent: ${accentColor};
    --nav-w: ${navW};
    --shadow-sm: 0 2px 8px rgba(20,16,8,0.22);
    --shadow-md: 0 8px 32px rgba(20,16,8,0.32);
    --radius-sm: 6px;
    --radius-md: 12px;
    --transition: 250ms ease;
  }
`} />
</head>
<body>
  <slot />
</body>
</html>
